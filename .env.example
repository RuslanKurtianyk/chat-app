# --- Local dev (optional) ---
# Leave empty to use SQLite in ./data/chat.sqlite
# DATABASE_URL=
# Або залиште DATABASE_URL для Render, а локально примусово SQLite:
# FORCE_SQLITE=true

# --- Supabase (PostgreSQL) ---
# Render (IPv4): якщо Direct «Not IPv4 compatible» → URI з Session pooler або Transaction pooler (*.pooler.supabase.com), не db.* direct.
# Приклад transaction pooler: postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# SSL: auto-enabled for *.supabase.co URLs. Override:
# DATABASE_SSL=true
# DATABASE_SSL=false
# На Render + Supabase інколи DNS дає лише IPv6 → ENETUNREACH; у main.ts за замовчуванням ipv4first.
# DATABASE_DNS_IPV4_FIRST=false
# Додатково TypeORM резолвить A-запис (IPv4) і підключається за IP + ssl.servername (див. postgres-ipv4-host.ts).
# DATABASE_IPV4_LOOKUP=false
# DATABASE_DNS_SERVERS=1.1.1.1,8.8.8.8

# Schema sync: in production defaults to false. Set true once for initial tables, then false + migrations.
# DATABASE_SYNC=true

# --- Render ---
# PORT is set automatically on Render
NODE_ENV=production

# CORS: точний Origin фронту через кому (без path). GitHub Pages: https://username.github.io
# CORS_ORIGIN=https://your-app.onrender.com,https://ruslankurtianyk.github.io
# Для localhost + Render API: додайте http://localhost:5173 або CORS_ALLOW_LOCALHOST=true
# CORS_ALLOW_LOCALHOST=true

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Cloudinary ---
# Dashboard → Settings / API credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Папка в Cloudinary (необовʼязково)
CLOUDINARY_FOLDER=chat-app
# Вмикає secure_url
CLOUDINARY_SECURE=true
# Unsigned upload preset (необовʼязково — сервер завантажує сам через POST /messages/upload)
CLOUDINARY_UPLOAD_PRESET=

# --- Local uploads (dev only) ---
# When enabled and Cloudinary creds are not set, uploaded files are stored on disk
# and served via GET /storage/local/:folder/:subfolder/:filename.
LOCAL_UPLOADS_ENABLED=true
LOCAL_UPLOAD_DIR=data/uploads
LOCAL_UPLOAD_ROUTE_BASE_PATH=/storage/local
# Optional: make returned URLs absolute (otherwise we return relative /storage/local/...)
# LOCAL_UPLOAD_PUBLIC_URL_PREFIX=http://localhost:3000

# Макс. розмір файлу для POST /messages/upload (байти)
UPLOAD_MAX_FILE_BYTES=26214400

# Макс. розмір base64 у WS sendMessageWithFile (байти)
WS_MAX_FILE_BYTES=2097152

# --- Optional: connection pool size (Postgres) ---
# DATABASE_POOL_MAX=10

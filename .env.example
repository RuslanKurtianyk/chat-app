# --- Local dev (optional) ---
# Leave empty to use SQLite in ./data/chat.sqlite
# DATABASE_URL=
# Або залиште DATABASE_URL для Render, а локально примусово SQLite:
# FORCE_SQLITE=true

# --- Supabase (PostgreSQL) ---
# Project Settings → Database → Connection string (URI), mode: Transaction pooler (recommended for serverless)
# Example: postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# SSL: auto-enabled for *.supabase.co URLs. Override:
# DATABASE_SSL=true
# DATABASE_SSL=false
# На Render + Supabase інколи DNS дає лише IPv6 → ENETUNREACH; у main.ts за замовчуванням ipv4first.
# DATABASE_DNS_IPV4_FIRST=false

# Schema sync: in production defaults to false. Set true once for initial tables, then false + migrations.
# DATABASE_SYNC=true

# --- Render ---
# PORT is set automatically on Render
NODE_ENV=production

# CORS: для фронту на іншому домені (через кому). Для доступу з localhost на Render API:
#   — додайте http://localhost:5173 (ваш порт), або
#   — CORS_ALLOW_LOCALHOST=true (типові localhost-порти з cors-settings.ts)
# CORS_ORIGIN=https://your-app.onrender.com,https://your-frontend.vercel.app
# CORS_ALLOW_LOCALHOST=true

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Cloudinary ---
# Dashboard → Settings / API credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Папка в Cloudinary (необовʼязково)
CLOUDINARY_FOLDER=chat-app
# Вмикає secure_url
CLOUDINARY_SECURE=true
# Unsigned upload preset (необовʼязково — сервер завантажує сам через POST /messages/upload)
CLOUDINARY_UPLOAD_PRESET=

# Макс. розмір файлу для POST /messages/upload (байти)
UPLOAD_MAX_FILE_BYTES=26214400

# Макс. розмір base64 у WS sendMessageWithFile (байти)
WS_MAX_FILE_BYTES=2097152

# --- Optional: connection pool size (Postgres) ---
# DATABASE_POOL_MAX=10
